// === lib/lib.go ===
package lib

import "fmt"

type Point struct {
	X int
	Y int
}

func (p Point) GoString() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.X, p.Y)
}

func Point_New(x, y int) Point {
	return Point{
		X: x,
		Y: y,
	}
}


// === main.go ===
package main

import L "github.com/user/myproject/lib"

func main() {
	_ = L.Point_New(3, 4)
}
