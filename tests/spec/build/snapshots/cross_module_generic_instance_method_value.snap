// === lib/lib.go ===
package lib

import "fmt"

type Box[T any] struct {
	Value T
}

func (b Box[T]) GoString() string {
	return fmt.Sprintf("Box { value: %v }", b.Value)
}

func (b Box[T]) Get() T {
	return b.Value
}


// === main.go ===
package main

import "github.com/user/myproject/lib"

func main() {
	b := lib.Box[int]{Value: 42}
	f := lib.Box[int].Get
	_ = f(b)
}
