// === main.go ===
package main

import (
	"flag"
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	raw_1 := flag.Lookup("verbose")
	var result lisette.Option[*flag.Flag]
	if raw_1 != nil {
		result = lisette.MakeOptionSome[*flag.Flag](raw_1)
	} else {
		result = lisette.MakeOptionNone[*flag.Flag]()
	}
	fmt.Print(result.IsSome())
}
