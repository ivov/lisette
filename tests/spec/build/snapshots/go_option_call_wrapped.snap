// === main.go ===
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"go/doc/comment"
)

func main() {
	ret_1, ret_2 := comment.DefaultLookupPackage("math")
	var result lisette.Option[string]
	if ret_2 {
		result = lisette.MakeOptionSome[string](ret_1)
	} else {
		result = lisette.MakeOptionNone[string]()
	}
	fmt.Print(result.IsSome())
}
