// === lib/mod.go ===
package lib

import "fmt"

type Box struct {
	X int
}

func (b Box) GoString() string {
	return fmt.Sprintf("Box { x: %v }", b.X)
}

func Box_New(x int) Box {
	return Box{X: x}
}

type Alias = Box


// === main.go ===
package main

import "github.com/user/myproject/lib"

func main() {
	b := lib.Box_New(1)
	_ = b.X
}
