// === lib/mod.go ===
package lib

import "fmt"

type Box[T any] struct {
	Val T
}

func (b Box[T]) String() string {
	return fmt.Sprintf("Box { val: %v }", b.Val)
}

func Box_New[T any](v T) Box[T] {
	return Box[T]{Val: v}
}


// === main.go ===
package main

import (
	"fmt"
	"github.com/user/myproject/lib"
)

func main() {
	b := lib.Box_New[int](42)
	fmt.Println(b.Val)
}
