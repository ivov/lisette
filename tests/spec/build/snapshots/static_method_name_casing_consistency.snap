// === api/lib.go ===
package api

import "fmt"

type Service struct {
	Name string
}

func (s Service) String() string {
	return fmt.Sprintf("Service { name: %v }", s.Name)
}

func Service_New(name string) Service {
	return Service{Name: name}
}


// === main.go ===
package main

import (
	"fmt"
	"github.com/user/myproject/api"
)

type Helper struct {
	value int
}

func (h Helper) String() string {
	return fmt.Sprintf("Helper { value: %v }", h.value)
}

func Helper_New(v int) Helper {
	return Helper{value: v}
}

func main() {
	svc := api.Service_New("test")
	h := Helper_New(42)
	_ = svc.Name
	_ = h.value
}
