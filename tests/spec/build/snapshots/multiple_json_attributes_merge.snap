// === main.go ===
package main

import (
	"encoding/json"
	"fmt"
)

type User struct {
	First_name  string `json:"firstName,omitempty"`
	Middle_name string `json:"middleName,omitempty"`
}

func (u User) String() string {
	return fmt.Sprintf("User { first_name: %v, middle_name: %v }", u.First_name, u.Middle_name)
}

func main() {
	u := User{
		First_name:  "Alice",
		Middle_name: "",
	}
	json.Marshal(u)
}
