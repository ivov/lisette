description: "input: \nfn make_adder(n: int) -> fn(int) -> int {\n  |x: int| x + n\n}\n\nfn test() -> int {\n  let add5 = make_adder(5);\n  add5(10)\n}\n"
---
package main

func make_adder(n int) func(int) int {
	return func(x int) int {
		return x + n
	}
}

func test() int {
	add5 := make_adder(5)
	return add5(10)
}
