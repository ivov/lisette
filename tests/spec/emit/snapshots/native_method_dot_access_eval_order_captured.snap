---
source: tests/spec/emit/expressions.rs
description: "input: \nfn bump(i: Ref<int>) -> int {\n  i.* = 1\n  10\n}\n\nfn main() {\n  let mut i = 0\n  let items = [10, 20, 30]\n  let v = items.contains(bump(&i))\n  let _ = v\n}\n"
---
package main

import "slices"

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	items := []int{10, 20, 30}
	_ = slices.Contains(items, bump(&i))
}
