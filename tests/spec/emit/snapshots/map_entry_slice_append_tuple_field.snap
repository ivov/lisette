source: tests/spec/emit/expressions.rs
description: "input: \nfn main() {\n  let mut m = Map.new<string, (Slice<int>, int)>()\n  m[\"a\"] = ([1], 2)\n  let mut entry = m[\"a\"]\n  entry.0 = entry.0.append(3)\n  m[\"a\"] = entry\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func main() {
	m := make(map[string]lisette.Tuple2[[]int, int])
	m["a"] = lisette.MakeTuple2([]int{1}, 2)
	entry := m["a"]
	entry.First = append(entry.First, 3)
	m["a"] = entry
}
