---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Inner { x: int }\nstruct Wrap(Inner)\n\nfn main() {\n  let mut w = Wrap(Inner { x: 1 })\n  let inner = w.0\n  let r = &inner.x\n  let _ = r\n}\n"
---
package main

import "fmt"

type Inner struct {
	x int
}

func (i Inner) GoString() string {
	return fmt.Sprintf("Inner { x: %v }", i.x)
}

type Wrap Inner

func (w Wrap) GoString() string {
	return fmt.Sprintf("Wrap(%v)", Inner(w))
}

func main() {
	w := Wrap(Inner{x: 1})
	inner := Inner(w)
	_ = &inner.x
}
