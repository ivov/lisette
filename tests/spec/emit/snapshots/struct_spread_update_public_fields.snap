---
source: tests/spec/emit/types.rs
description: "input: \nstruct Point { pub x: int, pub y: int }\n\nfn test() -> Point {\n  let p = Point { x: 1, y: 2 };\n  Point { x: 10, ..p }\n}\n"
---
package main

import "fmt"

type Point struct {
	X int
	Y int
}

func (p Point) String() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.X, p.Y)
}

func test() Point {
	p := Point{
		X: 1,
		Y: 2,
	}
	copy_1 := p
	copy_1.X = 10
	return copy_1
}
