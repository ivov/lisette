---
source: tests/spec/emit/functions.rs
description: "input: \nimport \"go:fmt\"\nimport \"go:strconv\"\n\nfn main() {\n  let cond = true\n  let f = if cond { strconv.Atoi } else { strconv.Atoi }\n  let r = f(\"99\")\n  fmt.Println(r)\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func main() {
	cond := true
	var f func(string) lisette.Result[int, error]
	if cond {
		f = func(arg0 string) lisette.Result[int, error] {
			ret_1, ret_2 := strconv.Atoi(arg0)
			if ret_2 != nil {
				return lisette.MakeResultErr[int, error](ret_2)
			}
			return lisette.MakeResultOk[int, error](ret_1)
		}
	} else {
		f = func(arg0 string) lisette.Result[int, error] {
			ret_4, ret_5 := strconv.Atoi(arg0)
			if ret_5 != nil {
				return lisette.MakeResultErr[int, error](ret_5)
			}
			return lisette.MakeResultOk[int, error](ret_4)
		}
	}
	r := f("99")
	fmt.Println(r)
}
