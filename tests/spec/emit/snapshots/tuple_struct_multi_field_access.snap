---
source: tests/spec/emit/types.rs
description: "input: \nstruct Point(int, int)\n\nfn test(p: Point) -> int {\n  p.0 + p.1\n}\n"
---
package main

import "fmt"

type Point struct {
	F0 int
	F1 int
}

func (p Point) String() string {
	return fmt.Sprintf("Point(%v, %v)", p.F0, p.F1)
}

func test(p Point) int {
	return p.F0 + p.F1
}
