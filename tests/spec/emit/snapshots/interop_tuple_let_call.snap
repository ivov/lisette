source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:path\"\n\nfn main() {\n  let f = path.Split\n  let r = f(\"/foo/bar.txt\")\n  let _ = r\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"path"
)

func main() {
	f := func(arg0 string) lisette.Tuple2[string, string] {
		ret_1, ret_2 := path.Split(arg0)
		return lisette.MakeTuple2(ret_1, ret_2)
	}
	_ = f("/foo/bar.txt")
}
