---
source: tests/spec/emit/prelude.rs
description: "input: \nfn test(s: Slice<int>) -> Option<int> {\n  s.find(|x| x > 0)\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(s []int) lisette.Option[int] {
	return lisette.SliceFind(s, func(x int) bool {
		return x > 0
	})
}
