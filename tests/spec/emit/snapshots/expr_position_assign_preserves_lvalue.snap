---
source: tests/spec/emit/expressions.rs
description: "input: \nimport \"go:fmt\"\n\nfn idx() -> int { let _ = fmt.Println(\"idx\"); 0 }\nfn cond() -> bool { let _ = fmt.Println(\"cond\"); true }\n\nfn main() {\n  let mut s = [1]\n  let _ = { s[idx()] = if cond() { 2 } else { 3 } }\n  let _ = fmt.Println(s[0])\n}\n"
---
package main

import "fmt"

func idx() int {
	fmt.Println("idx")
	return 0
}

func cond() bool {
	fmt.Println("cond")
	return true
}

func main() {
	s := []int{1}
	idx_2 := idx()
	var tmp_1 int
	if cond() {
		tmp_1 = 2
	} else {
		tmp_1 = 3
	}
	s[idx_2] = tmp_1
	fmt.Println(s[0])
}
