---
source: tests/spec/emit/expressions.rs
description: "input: \nfn bump(i: Ref<int>) -> int {\n  i.* = 1\n  10\n}\n\nfn main() {\n  let items = [10, 20, 30, 40, 50]\n  let mut i = 1\n  let s = items[i..bump(&i)]\n  let _ = s\n}\n"
---
package main

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	items := []int{10, 20, 30, 40, 50}
	i := 1
	end_1 := bump(&i)
	_ = items[i:end_1:end_1]
}
