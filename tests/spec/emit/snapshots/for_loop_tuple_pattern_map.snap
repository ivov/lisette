source: tests/spec/emit/control_flow.rs
description: "input: \nfn test(m: Map<string, int>) -> int {\n  let mut sum = 0;\n  for (_, value) in m {\n    sum = sum + value;\n  };\n  sum\n}\n"
---
package main

func test(m map[string]int) int {
	sum := 0
	for _, value := range m {
		sum += value
	}
	return sum
}
