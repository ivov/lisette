---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn get_option() -> Option<int> { Some(42) }\n\nfn test() -> int {\n  match get_option() {\n    Some(x) if x > 0 => x,\n    Some(_) => 0,\n    None => -1,\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func get_option() lisette.Option[int] {
	return lisette.MakeOptionSome[int](42)
}

func test() int {
	subject_1 := get_option()
	if subject_1.Tag == lisette.OptionSome {
		x := subject_1.SomeVal
		if x > 0 {
			return x
		}
		return 0
	}
	return -1
}
