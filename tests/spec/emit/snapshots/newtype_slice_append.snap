---
package main

import "fmt"

type Wrap []int

func (w Wrap) String() string {
	return fmt.Sprintf("Wrap(%v)", []int(w))
}

func main() {
	w := Wrap([]int{1})
	w = Wrap(append([]int(w), 2))
}
