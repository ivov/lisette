description: "input: \nfn test(s: Slice<int>) -> int {\n  s.fold(0, |acc, x| acc + x)\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(s []int) int {
	return lisette.SliceFold(s, 0, func(acc, x int) int {
		return acc + x
	})
}
