---
source: tests/spec/emit/types.rs
description: "input: \nstruct Box<T> { value: T }\n\nfn test() -> Box<Box<int>> {\n  Box { value: Box { value: 42 } }\n}\n"
---
package main

import "fmt"

type Box[T any] struct {
	value T
}

func (b Box[T]) GoString() string {
	return fmt.Sprintf("Box { value: %v }", b.value)
}

func test() Box[Box[int]] {
	return Box[Box[int]]{value: Box[int]{value: 42}}
}
