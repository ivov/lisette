---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Wrap(int)\n\nfn main() {\n  let mut w = Wrap(0)\n  let r = &w\n  let _ = { r.* = Wrap(1) }\n  let _ = w.0\n}\n"
---
package main

import "fmt"

type Wrap int

func (w Wrap) String() string {
	return fmt.Sprintf("Wrap(%v)", int(w))
}

func main() {
	w := Wrap(0)
	r := &w
	*r = Wrap(1)
	_ = int(w)
}
