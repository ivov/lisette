---
source: tests/spec/emit/control_flow.rs
description: "input: \nstruct Point { x: int, y: int }\n\nimpl Point {\n  fn sum(self) -> int { self.x + self.y }\n}\n\nfn test() -> int {\n  if Point { x: 1, y: 2 }.sum() > 0 {\n    1\n  } else {\n    0\n  }\n}\n"
---
package main

import "fmt"

type Point struct {
	x int
	y int
}

func (p Point) String() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.x, p.y)
}

func (p Point) sum() int {
	return p.x + p.y
}

func test() int {
	if (Point{
		x: 1,
		y: 2,
	}.sum() > 0) {
		return 1
	}
	return 0
}
