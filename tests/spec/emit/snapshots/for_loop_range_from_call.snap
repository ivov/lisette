---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn get_range() -> Range<int> { 0..5 }\n\nfn test() -> int {\n  let mut sum = 0;\n  for i in get_range() {\n    sum = sum + i;\n  };\n  sum\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func get_range() lisette.Range[int] {
	return lisette.Range[int]{
		Start: 0,
		End:   5,
	}
}

func test() int {
	sum := 0
	_range_1 := get_range()
	for i := _range_1.Start; i < _range_1.End; i++ {
		sum += i
	}
	return sum
}
