---
source: tests/spec/emit/types.rs
description: "input: \nstruct Point(int, int)\n\nfn test() -> Point {\n  Point(10, 20)\n}\n"
---
package main

import "fmt"

type Point struct {
	F0 int
	F1 int
}

func (p Point) GoString() string {
	return fmt.Sprintf("Point(%v, %v)", p.F0, p.F1)
}

func test() Point {
	return Point{
		F0: 10,
		F1: 20,
	}
}
