source: tests/spec/emit/concurrency.rs
description: "input: \nimport \"go:fmt\"\n\nfn background() {\n  fmt.Print(f\"Running in background\");\n}\n\nfn test() -> int {\n  let x = 42;\n  task background();\n  x\n}\n"
---
package main

import "fmt"

func background() {
	fmt.Print("Running in background")
}

func test() int {
	x := 42
	go background()
	return x
}
