---
source: tests/spec/emit/concurrency.rs
description: "input: \nfn record(acc: Ref<int>, digit: int) {\n  acc.* = acc.* * 10 + digit\n}\n\nfn test() -> int {\n  let mut acc = 0;\n  {\n    defer record(&acc, 1);\n    record(&acc, 2)\n  };\n  record(&acc, 3);\n  acc\n}\n"
---
package main

func record(acc *int, digit int) {
	*acc = *acc*10 + digit
}

func test() int {
	acc := 0
	{
		defer record(&acc, 1)
		record(&acc, 2)
	}
	record(&acc, 3)
	return acc
}
