---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn test_int() -> Option<int> {\n  Some(42)\n}\n\nfn test_string() -> Option<string> {\n  Some(\"hello\")\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test_int() lisette.Option[int] {
	return lisette.MakeOptionSome[int](42)
}

func test_string() lisette.Option[string] {
	return lisette.MakeOptionSome[string]("hello")
}
