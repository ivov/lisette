---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn test() -> int {\n  let triple = (1, 2, 3);\n  match triple {\n    (1, _, _) => 1,\n    (_, 2, _) => 2,\n    (_, _, 3) => 3,\n    _ => 0,\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() int {
	triple := lisette.MakeTuple3(1, 2, 3)
	if triple.First == 1 {
		return 1
	} else if triple.Second == 2 {
		return 2
	} else if triple.Third == 3 {
		return 3
	}
	return 0
}
