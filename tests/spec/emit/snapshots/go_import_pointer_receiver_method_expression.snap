package main

import (
	"bytes"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	fn_1 := (*bytes.Buffer).ReadString
	f := func(arg0 *bytes.Buffer, arg1 uint8) lisette.Result[string, error] {
		ret_2, ret_3 := fn_1(arg0, arg1)
		if ret_3 != nil {
			return lisette.MakeResultErr[string, error](ret_3)
		}
		return lisette.MakeResultOk[string, error](ret_2)
	}
	buf := bytes.Buffer{}
	_ = f(&buf, 10)
}
