---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn get_value() -> Option<int> {\n  Some(42)\n}\n\nfn test() {\n  let mut opt: Option<int> = None;\n  opt = get_value();\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func get_value() lisette.Option[int] {
	return lisette.MakeOptionSome[int](42)
}

func test() {
	_ = lisette.MakeOptionNone[int]()
	_ = get_value()
}
