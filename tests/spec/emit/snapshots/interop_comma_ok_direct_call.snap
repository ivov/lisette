source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:os\"\n\nfn main() {\n  let r = os.LookupEnv(\"HOME\")\n  match r {\n    Some(v) => { let _ = v },\n    None => { let _ = \"\" },\n  }\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"os"
)

func main() {
	ret_1, ret_2 := os.LookupEnv("HOME")
	var r lisette.Option[string]
	if ret_2 {
		r = lisette.MakeOptionSome[string](ret_1)
	} else {
		r = lisette.MakeOptionNone[string]()
	}
	if r.Tag == lisette.OptionSome {
		_ = r.SomeVal
	} else {
		_ = ""
	}
}
