---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn test() -> int {\n  let r = 0..;\n  let mut sum = 0;\n  for i in r {\n    if i >= 5 {\n      break;\n    }\n    sum = sum + i;\n  };\n  sum\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() int {
	r := lisette.RangeFrom[int]{Start: 0}
	sum := 0
	for i := r.Start; ; i++ {
		if i >= 5 {
			break
		}
		sum += i
	}
	return sum
}
