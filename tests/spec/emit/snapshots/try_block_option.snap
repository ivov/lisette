---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn maybe_get() -> Option<int> {\n  Some(42)\n}\n\nfn test() -> int {\n  let opt: Option<int> = try {\n    let x = maybe_get()?;\n    x + 1\n  };\n  match opt {\n    Some(v) => v,\n    None => 0,\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func maybe_get() lisette.Option[int] {
	return lisette.MakeOptionSome[int](42)
}

func test() int {
	var opt lisette.Option[int]
	tryResult_1 := func() lisette.Option[int] {
		check_2 := maybe_get()
		if check_2.Tag != lisette.OptionSome {
			return lisette.MakeOptionNone[int]()
		}
		x := check_2.SomeVal
		return lisette.MakeOptionSome[int](x + 1)
	}()
	opt = tryResult_1
	if opt.Tag == lisette.OptionSome {
		return opt.SomeVal
	}
	return 0
}
