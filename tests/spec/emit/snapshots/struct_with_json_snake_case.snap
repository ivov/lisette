---
package main

import "fmt"

type User struct {
	First_name string `json:"first_name"`
	Last_name  string `json:"last_name"`
}

func (u User) GoString() string {
	return fmt.Sprintf("User { first_name: %v, last_name: %v }", u.First_name, u.Last_name)
}
