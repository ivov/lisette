source: tests/spec/emit/types.rs
description: "input: \nimport \"go:errors\"\n\nfn might_fail(n: int) -> Result<int, error> {\n  if n < 0 {\n    return Err(errors.New(\"negative\"))\n  }\n  Ok(n)\n}\n"
---
package main

import (
	"errors"
	lisette "github.com/ivov/lisette/prelude"
)

func might_fail(n int) lisette.Result[int, error] {
	if n < 0 {
		return lisette.MakeResultErr[int, error](errors.New("negative"))
	}
	return lisette.MakeResultOk[int, error](n)
}
