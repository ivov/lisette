---
source: tests/spec/emit/expressions.rs
description: "input: \nfn bump(i: Ref<int>) -> int {\n  i.* = 1\n  10\n}\n\nfn main() {\n  let mut i = 0\n  let t = (i, bump(&i))\n  let _ = t\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func bump(i *int) int {
	*i = 1
	return 10
}

func main() {
	i := 0
	_ = lisette.MakeTuple2(i, bump(&i))
}
