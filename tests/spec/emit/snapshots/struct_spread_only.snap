---
source: tests/spec/emit/types.rs
description: "input: \nstruct Point { x: int, y: int }\n\nfn test() -> Point {\n  let base = Point { x: 1, y: 2 };\n  Point { ..base }\n}\n"
---
package main

import "fmt"

type Point struct {
	x int
	y int
}

func (p Point) String() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.x, p.y)
}

func test() Point {
	base := Point{
		x: 1,
		y: 2,
	}
	return base
}
