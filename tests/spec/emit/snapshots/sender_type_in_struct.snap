---
source: tests/spec/emit/concurrency.rs
description: "input: \nstruct Producer { output: Sender<int> }\n\nfn test(p: Producer) -> Sender<int> {\n  p.output\n}\n"
---
package main

import "fmt"

type Producer struct {
	output chan<- int
}

func (p Producer) String() string {
	return fmt.Sprintf("Producer { output: %v }", p.output)
}

func test(p Producer) chan<- int {
	return p.output
}
