---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn test(n: int) -> Option<int> {\n  match n {\n    1 => Some(10),\n    2 => Some(20),\n    _ => None,\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(n int) lisette.Option[int] {
	switch n {
	case 1:
		return lisette.MakeOptionSome[int](10)
	case 2:
		return lisette.MakeOptionSome[int](20)
	default:
		return lisette.MakeOptionNone[int]()
	}
}
