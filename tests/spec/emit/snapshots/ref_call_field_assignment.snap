---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Item { x: int }\n\nfn get() -> Ref<Item> { &Item { x: 0 } }\n\nfn main() {\n  get().x = 1\n}\n"
---
package main

import "fmt"

type Item struct {
	x int
}

func (i Item) GoString() string {
	return fmt.Sprintf("Item { x: %v }", i.x)
}

func get() *Item {
	return &Item{x: 0}
}

func main() {
	ref_1 := get()
	ref_1.x = 1
}
