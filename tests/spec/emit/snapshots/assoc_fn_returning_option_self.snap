source: tests/spec/emit/types.rs
description: "input: \nstruct Thing {\n  name: string,\n}\n\nimpl Thing {\n  fn maybe_create(name: string) -> Option<Thing> {\n    if name.length() > 0 { Some(Thing { name: name }) }\n    else { None }\n  }\n}\n\nfn test() -> Option<Thing> {\n  Thing.maybe_create(\"hello\")\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

type Thing struct {
	name string
}

func (t Thing) GoString() string {
	return fmt.Sprintf("Thing { name: %v }", t.name)
}

func Thing_maybe_create(name string) lisette.Option[Thing] {
	if len(name) > 0 {
		return lisette.MakeOptionSome[Thing](Thing{name: name})
	}
	return lisette.MakeOptionNone[Thing]()
}

func test() lisette.Option[Thing] {
	return Thing_maybe_create("hello")
}
