---
source: tests/spec/emit/types.rs
description: "input: \ntype Transformer = fn(int) -> int\n\nfn apply(t: Transformer, val: int) -> int {\n  t(val)\n}\n\nfn double(x: int) -> int {\n  x * 2\n}\n\nfn test() -> int {\n  apply(double, 21)\n}\n"
---
package main

type Transformer = func(int) int

func apply(t Transformer, val int) int {
	return t(val)
}

func double(x int) int {
	return x * 2
}

func test() int {
	return apply(double, 21)
}
