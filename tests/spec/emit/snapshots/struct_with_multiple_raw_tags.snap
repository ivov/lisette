description: "input: \n#[tag(\"validate\")]\n#[tag(\"custom\")]\nstruct User {\n  #[tag(`validate:\"required\"`)]\n  #[tag(`custom:\"foo\"`)]\n  name: string,\n}\n"
---
package main

import "fmt"

type User struct {
	Name string `custom:"foo" validate:"required"`
}

func (u User) GoString() string {
	return fmt.Sprintf("User { name: %v }", u.Name)
}
