package main

import "fmt"

type Counter struct {
	count int
}

func (c Counter) GoString() string {
	return fmt.Sprintf("Counter { count: %v }", c.count)
}

// Creates a new counter starting at zero.
func Counter_new() Counter {
	return Counter{count: 0}
}
