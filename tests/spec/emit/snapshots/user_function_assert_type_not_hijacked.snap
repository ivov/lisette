source: tests/spec/emit/expressions.rs
description: "input: \nfn assert_type(x: int) -> Option<int> {\n  Some(x)\n}\n\nfn test() -> Option<int> {\n  assert_type(42)\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func assert_type(x int) lisette.Option[int] {
	return lisette.MakeOptionSome[int](x)
}

func test() lisette.Option[int] {
	return assert_type(42)
}
