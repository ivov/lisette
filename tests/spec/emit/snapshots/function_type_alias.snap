---
source: tests/spec/emit/types.rs
description: "input: \ntype IntPredicate = fn(int) -> bool\n\nfn apply(f: IntPredicate, x: int) -> bool {\n  f(x)\n}\n\nfn test() -> bool {\n  apply(|x| x > 0, 42)\n}\n"
---
package main

type IntPredicate func(int) bool

func apply(f IntPredicate, x int) bool {
	return f(x)
}

func test() bool {
	return apply(func(x int) bool {
		return x > 0
	}, 42)
}
