---
source: tests/spec/emit/types.rs
description: "input: \nstruct Point { x: int, y: int }\n\nimpl Point {\n  fn sum(self) -> int {\n    self.x + self.y\n  }\n}\n\nfn main() {\n  let p = Point { x: 10, y: 20 };\n  let s = p.sum();\n}\n"
---
package main

import "fmt"

type Point struct {
	x int
	y int
}

func (p Point) GoString() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.x, p.y)
}

func (p Point) sum() int {
	return p.x + p.y
}

func main() {
	p := Point{
		x: 10,
		y: 20,
	}
	_ = p.sum()
}
