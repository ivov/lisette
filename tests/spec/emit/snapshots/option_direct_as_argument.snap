---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn maybe_int(b: bool) -> Option<int> {\n  if b { Some(42) } else { None }\n}\n\nfn unwrap_or(o: Option<int>, fallback: int) -> int {\n  match o { Some(v) => v, None => fallback }\n}\n\nfn test() -> int {\n  unwrap_or(maybe_int(true), 0)\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func maybe_int(b bool) lisette.Option[int] {
	if b {
		return lisette.MakeOptionSome[int](42)
	}
	return lisette.MakeOptionNone[int]()
}

func unwrap_or(o lisette.Option[int], fallback int) int {
	if o.Tag == lisette.OptionSome {
		return o.SomeVal
	}
	return fallback
}

func test() int {
	return unwrap_or(maybe_int(true), 0)
}
