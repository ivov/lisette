---
package main

import "fmt"

type W[T any] struct {
	F0 T
}

func (w W[T]) GoString() string {
	return fmt.Sprintf("W(%v)", w.F0)
}

func test() int {
	w := W[int]{F0: 1}
	if w == (W[int]{F0: 2}) {
		return 0
	}
	return 1
}
