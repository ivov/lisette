---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nimport \"go:fmt\"\n\nfn foo() -> Result<int, string> {\n  let x = Ok(1)?\n  let check_1 = 7\n  fmt.Println(check_1)\n  Ok(x)\n}\n\nfn main() {\n  let _ = foo()\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func foo() lisette.Result[int, string] {
	check_1 := lisette.MakeResultOk[int, string](1)
	if check_1.Tag != lisette.ResultOk {
		return lisette.MakeResultErr[int, string](check_1.ErrVal)
	}
	x := check_1.OkVal
	check_1_2 := 7
	fmt.Println(check_1_2)
	return lisette.MakeResultOk[int, string](x)
}

func main() {
	_ = foo()
}
