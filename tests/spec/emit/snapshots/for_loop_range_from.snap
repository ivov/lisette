---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn test() -> int {\n  let mut sum = 0;\n  for i in 0.. {\n    if i >= 5 {\n      break;\n    }\n    sum = sum + i;\n  };\n  sum\n}\n"
---
package main

func test() int {
	sum := 0
	for i := 0; ; i++ {
		if i >= 5 {
			break
		}
		sum += i
	}
	return sum
}
