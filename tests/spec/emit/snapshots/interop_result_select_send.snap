---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:strconv\"\n\nfn main() {\n  let ch = Channel.new<fn(string) -> Result<int, error>>()\n  select {\n    ch.send(strconv.Atoi) => { let _ = 0 },\n    _ => { let _ = 1 },\n  }\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func main() {
	ch := make(chan func(string) lisette.Result[int, error])
	select {
	case ch <- func(arg0 string) lisette.Result[int, error] {
		ret_1, ret_2 := strconv.Atoi(arg0)
		if ret_2 != nil {
			return lisette.MakeResultErr[int, error](ret_2)
		}
		return lisette.MakeResultOk[int, error](ret_1)
	}:
		_ = 0
	default:
		_ = 1
	}
}
