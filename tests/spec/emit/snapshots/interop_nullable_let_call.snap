description: "input: \nimport \"go:flag\"\n\nfn main() {\n  let f = flag.Lookup\n  let r = f(\"verbose\")\n  match r {\n    Some(v) => { let _ = v },\n    None => {},\n  }\n}\n"
---
package main

import (
	"flag"
	lisette "github.com/ivov/lisette/prelude"
)

func main() {
	f := func(arg0 string) lisette.Option[*flag.Flag] {
		raw_1 := flag.Lookup(arg0)
		if raw_1 != nil {
			return lisette.MakeOptionSome[*flag.Flag](raw_1)
		}
		return lisette.MakeOptionNone[*flag.Flag]()
	}
	r := f("verbose")
	if r.Tag == lisette.OptionSome {
		_ = r.SomeVal
	}
}
