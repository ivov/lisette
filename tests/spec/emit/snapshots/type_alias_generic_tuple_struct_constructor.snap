package main

import "fmt"

type Wrapper[T any] struct {
	F0 T
}

func (w Wrapper[T]) GoString() string {
	return fmt.Sprintf("Wrapper(%v)", w.F0)
}

type W[T any] = Wrapper[T]

func test() Wrapper[int] {
	return Wrapper[int]{F0: 5}
}
