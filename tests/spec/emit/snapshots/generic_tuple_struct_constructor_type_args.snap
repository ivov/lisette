package main

import "fmt"

type Wrapper[T any] struct {
	F0 T
}

func (w Wrapper[T]) GoString() string {
	return fmt.Sprintf("Wrapper(%v)", w.F0)
}

func main() {
	w := Wrapper[int]{F0: 1}
	_ = w.F0 + 1
}
