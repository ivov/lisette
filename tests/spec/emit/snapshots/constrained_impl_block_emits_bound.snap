---
source: tests/spec/emit/types.rs
description: "input: \ninterface Displayable {\n  fn display(self) -> string\n}\n\nstruct Labeled<T> {\n  label: string,\n  value: T,\n}\n\nimpl<T: Displayable> Labeled<T> {\n  fn show(self) -> string {\n    self.label\n  }\n}\n"
---
package main

import "fmt"

type Displayable interface {
	display() string
}

type Labeled[T Displayable] struct {
	label string
	value T
}

func (l Labeled[T]) GoString() string {
	return fmt.Sprintf("Labeled { label: %v, value: %v }", l.label, l.value)
}

func (l Labeled[T]) show() string {
	return l.label
}
