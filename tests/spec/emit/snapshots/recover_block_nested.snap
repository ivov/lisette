package main

import lisette "github.com/ivov/lisette/prelude"

func test() {
	recoverResult_1 := lisette.RecoverBlock(func() int {
		recoverResult_2 := lisette.RecoverBlock(func() int {
			return 1
		})
		_ = recoverResult_2
		return 2
	})
	_ = recoverResult_1
}
