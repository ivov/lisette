package main

import "fmt"

type P struct {
	v int
}

func (p P) String() string {
	return fmt.Sprintf("P { v: %v }", p.v)
}

func test() {
	for _, item_1 := range []P{P{v: 1}} {
		_ = item_1
	}
}
