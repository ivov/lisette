---
source: tests/spec/emit/expressions.rs
description: "input: \nimport \"go:fmt\"\nimport \"go:strconv\"\n\nfn parse_with(f: fn(string) -> Result<int, error>, s: string) -> int {\n  match f(s) {\n    Ok(n) => n,\n    Err(_) => 0,\n  }\n}\n\nfn main() {\n  let n = parse_with(strconv.Atoi, \"42\")\n  fmt.Println(n)\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func parse_with(f func(string) lisette.Result[int, error], s string) int {
	subject_1 := f(s)
	if subject_1.Tag == lisette.ResultOk {
		return subject_1.OkVal
	}
	return 0
}

func main() {
	n := parse_with(func(arg0 string) lisette.Result[int, error] {
		ret_1, ret_2 := strconv.Atoi(arg0)
		if ret_2 != nil {
			return lisette.MakeResultErr[int, error](ret_2)
		}
		return lisette.MakeResultOk[int, error](ret_1)
	}, "42")
	fmt.Println(n)
}
