---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:strconv\"\n\ntype F = fn(string) -> Result<int, error>\n\nfn main() {\n  let mut xs: Slice<F> = []\n  xs = xs.append(strconv.Atoi)\n  let _ = xs\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

type F func(string) lisette.Result[int, error]

func main() {
	xs := []F{}
	xs = append(xs, func(arg0 string) lisette.Result[int, error] {
		ret_1, ret_2 := strconv.Atoi(arg0)
		if ret_2 != nil {
			return lisette.MakeResultErr[int, error](ret_2)
		}
		return lisette.MakeResultOk[int, error](ret_1)
	})
	_ = xs
}
