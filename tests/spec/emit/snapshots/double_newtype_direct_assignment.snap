package main

import "fmt"

type A int

func (a A) GoString() string {
	return fmt.Sprintf("A(%v)", int(a))
}

type B A

func (b B) GoString() string {
	return fmt.Sprintf("B(%v)", A(b))
}

func main() {
	_ = B(A(1))
	_ = B(A(2))
}
