description: "input: \nfn test(items: Slice<int>) -> int {\n  match items {\n    [a, b, c] => a + b + c,\n    _ => 0,\n  }\n}\n"
---
package main

func test(items []int) int {
	if len(items) == 3 {
		a := items[0]
		b := items[1]
		c := items[2]
		return a + b + c
	}
	return 0
}
