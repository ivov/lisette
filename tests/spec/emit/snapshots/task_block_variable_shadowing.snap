---
source: tests/spec/emit/concurrency.rs
description: "input: \nimport \"go:fmt\"\n\nfn main() {\n  let x = 1\n  fmt.Println(x)\n  task {\n    let x = 2\n    fmt.Println(x)\n    let x = 3\n    fmt.Println(x)\n  }\n}\n"
---
package main

import "fmt"

func main() {
	x := 1
	fmt.Println(x)
	go func() {
		x := 2
		fmt.Println(x)
		x_1 := 3
		fmt.Println(x_1)
	}()
}
