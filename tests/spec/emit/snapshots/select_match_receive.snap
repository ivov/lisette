---
source: tests/spec/emit/concurrency.rs
description: "input: \nfn process(v: int) {}\nfn handle_close() {}\n\nfn test() {\n  let ch = Channel.new<int>();\n  select {\n    match ch.receive() {\n      Some(v) => process(v),\n      None => handle_close(),\n    },\n    _ => {},\n  }\n}\n"
---
package main

func process(_ int) {}

func handle_close() {}

func test() {
	ch := make(chan int)
	select {
	case v, ok := <-ch:
		if ok {
			process(v)
		} else {
			handle_close()
		}
	default:
	}
}
