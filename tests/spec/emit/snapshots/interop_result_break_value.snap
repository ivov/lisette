---
source: tests/spec/emit/interop_matrix.rs
description: "input: \nimport \"go:strconv\"\n\nfn make() -> fn(string) -> Result<int, error> {\n  loop {\n    break strconv.Atoi\n  }\n}\n\nfn main() {\n  let f = make()\n  let r = f(\"1\")\n  match r {\n    Ok(v) => { let _ = v },\n    Err(_) => { let _ = 0 },\n  }\n}\n"
---
package main

import (
	lisette "github.com/ivov/lisette/prelude"
	"strconv"
)

func make_() func(string) lisette.Result[int, error] {
	var tmp_1 func(string) lisette.Result[int, error]
	for {
		tmp_1 = func(arg0 string) lisette.Result[int, error] {
			ret_2, ret_3 := strconv.Atoi(arg0)
			if ret_3 != nil {
				return lisette.MakeResultErr[int, error](ret_3)
			}
			return lisette.MakeResultOk[int, error](ret_2)
		}
		break
	}
	return tmp_1
}

func main() {
	f := make_()
	r := f("1")
	if r.Tag == lisette.ResultOk {
		_ = r.OkVal
	} else {
		_ = 0
	}
}
