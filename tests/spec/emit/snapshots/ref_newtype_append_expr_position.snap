source: tests/spec/emit/expressions.rs
description: "input: \nstruct Wrap(Slice<int>)\n\nfn main() {\n  let mut w = Wrap([1])\n  let r = &w\n  let _ = r.0.append(2)\n}\n"
---
package main

import "fmt"

type Wrap []int

func (w Wrap) GoString() string {
	return fmt.Sprintf("Wrap(%v)", []int(w))
}

func main() {
	w := Wrap([]int{1})
	r := &w
	_ = append([]int(*r), 2)
}
