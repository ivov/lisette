---
source: tests/spec/emit/functions.rs
description: "input: \nimport fmt \"go:fmt\"\nimport os \"go:os\"\n\nfn main() {\n  let f = fmt.Fprintf\n  let _ = f(os.Stdout, \"hi %d\", 3)\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
	"io"
	"os"
)

func main() {
	f := func(arg0 io.Writer, arg1 string, arg2 ...any) lisette.Result[int, error] {
		ret_1, ret_2 := fmt.Fprintf(arg0, arg1, arg2...)
		if ret_2 != nil {
			return lisette.MakeResultErr[int, error](ret_2)
		}
		return lisette.MakeResultOk[int, error](ret_1)
	}
	_ = f(os.Stdout, "hi %d", 3)
}
