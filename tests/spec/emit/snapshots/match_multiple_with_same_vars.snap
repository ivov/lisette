---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn test() -> int {\n  let pair = (10, 20);\n  let first = match pair {\n    (a, b) => a + b,\n  };\n\n  let nested = ((1, 2), (3, 4));\n  let second = match nested {\n    ((a, b), (c, d)) => a + b + c + d,\n  };\n\n  first + second\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() int {
	pair := lisette.MakeTuple2(10, 20)
	var first int
	a := pair.First
	b := pair.Second
	first = a + b
	nested := lisette.MakeTuple2(lisette.MakeTuple2(1, 2), lisette.MakeTuple2(3, 4))
	var second int
	a_1 := nested.First.First
	b_2 := nested.First.Second
	c := nested.Second.First
	d := nested.Second.Second
	second = a_1 + b_2 + c + d
	return first + second
}
