---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn test(opt: Option<int>) -> int {\n  let mut current = opt;\n  let mut sum = 0;\n  while let Some(1) | Some(2) | Some(3) = current {\n    sum = sum + 1;\n    current = None;\n  }\n  sum\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(opt lisette.Option[int]) int {
	current := opt
	sum := 0
	for {
		if (current.Tag == lisette.OptionSome && current.SomeVal == 1) || (current.Tag == lisette.OptionSome && current.SomeVal == 2) || (current.Tag == lisette.OptionSome && current.SomeVal == 3) {
			sum++
			current = lisette.MakeOptionNone[int]()
		} else {
			break
		}
	}
	return sum
}
