---
source: tests/spec/emit/expressions.rs
description: "input: \npub interface IFoo {\n  fn foo(self) -> int\n}\n\nstruct S {\n  foo: int,\n}\n\nfn main() {\n  let s = S { foo: 1 }\n  let _ = s.foo\n}\n"
---
package main

import "fmt"

type IFoo interface {
	Foo() int
}

type S struct {
	foo int
}

func (s S) String() string {
	return fmt.Sprintf("S { foo: %v }", s.foo)
}

func main() {
	s := S{foo: 1}
	_ = s.foo
}
