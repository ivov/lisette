---
source: tests/spec/emit/functions.rs
description: "input: \nstruct Point { pub x: int, pub y: int }\n\nfn get_x(Point { x, .. }: Point) -> int {\n  x\n}\n"
---
package main

import "fmt"

type Point struct {
	X int
	Y int
}

func (p Point) GoString() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.X, p.Y)
}

func get_x(arg_1 Point) int {
	return arg_1.X
}
