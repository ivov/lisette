---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn get_value(s: string) -> Option<int> {\n  if s == \"ok\" { Some(42) } else { None }\n}\n\nfn test() -> int {\n  let Some(x) = get_value(\"ok\") else { return 0; };\n  x\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func get_value(s string) lisette.Option[int] {
	if s == "ok" {
		return lisette.MakeOptionSome[int](42)
	}
	return lisette.MakeOptionNone[int]()
}

func test() int {
	subject_1 := get_value("ok")
	if subject_1.Tag != lisette.OptionSome {
		return 0
	}
	return subject_1.SomeVal
}
