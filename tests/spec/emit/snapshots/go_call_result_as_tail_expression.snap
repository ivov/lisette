---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nimport \"go:fmt\"\n\nfn print_hello() -> Result<int, error> {\n  fmt.Println(\"hello\")\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

func print_hello() lisette.Result[int, error] {
	ret_1, ret_2 := fmt.Println("hello")
	if ret_2 != nil {
		return lisette.MakeResultErr[int, error](ret_2)
	}
	return lisette.MakeResultOk[int, error](ret_1)
}
