---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nstruct MultiWrapper {\n  first: Option<int>,\n  second: Option<string>,\n}\n\nfn get_int(x: int) -> Option<int> {\n  if x > 0 { Some(x) } else { None }\n}\n\nfn get_string(s: string) -> Option<string> {\n  if s != \"\" { Some(s) } else { None }\n}\n\nfn test() {\n  let w = MultiWrapper {\n    first: get_int(5),\n    second: get_string(\"hello\")\n  };\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

type MultiWrapper struct {
	first  lisette.Option[int]
	second lisette.Option[string]
}

func (m MultiWrapper) GoString() string {
	return fmt.Sprintf("MultiWrapper { first: %v, second: %v }", m.first, m.second)
}

func get_int(x int) lisette.Option[int] {
	if x > 0 {
		return lisette.MakeOptionSome[int](x)
	}
	return lisette.MakeOptionNone[int]()
}

func get_string(s string) lisette.Option[string] {
	if s != "" {
		return lisette.MakeOptionSome[string](s)
	}
	return lisette.MakeOptionNone[string]()
}

func test() {
	_ = MultiWrapper{
		first:  get_int(5),
		second: get_string("hello"),
	}
}
