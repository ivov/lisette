---
source: tests/spec/emit/expressions.rs
description: "input: \nstruct Point { x: int, y: int }\n\nfn test(p: Point) {\n  p.x\n}\n"
---
package main

import "fmt"

type Point struct {
	x int
	y int
}

func (p Point) String() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.x, p.y)
}

func test(p Point) {
	_ = p.x
}
