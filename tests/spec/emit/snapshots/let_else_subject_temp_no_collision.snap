---
source: tests/spec/emit/expressions.rs
description: "input: \nfn main() {\n  let opt = Some(1);\n  let Some(x) = opt else { return; };\n  let subject_1 = 7;\n  let _ = x;\n  let _ = subject_1;\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func main() {
	opt := lisette.MakeOptionSome(1)
	if opt.Tag != lisette.OptionSome {
		return
	}
	x := opt.SomeVal
	subject_1 := 7
	_ = x
	_ = subject_1
}
