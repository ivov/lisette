---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn test(items: Slice<int>) -> int {\n  let mut sum = 0;\n  for item in items {\n    sum = sum + item;\n  };\n  sum\n}\n"
---
package main

func test(items []int) int {
	sum := 0
	for _, item := range items {
		sum += item
	}
	return sum
}
