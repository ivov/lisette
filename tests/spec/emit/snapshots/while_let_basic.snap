---
source: tests/spec/emit/control_flow.rs
description: "input: \nfn test(opt: Option<int>) {\n  let mut current = opt;\n  while let Some(x) = current {\n    current = None;\n    let _ = x;\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(opt lisette.Option[int]) {
	current := opt
	for {
		if current.Tag == lisette.OptionSome {
			x := current.SomeVal
			current = lisette.MakeOptionNone[int]()
			_ = x
		} else {
			break
		}
	}
}
