---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nstruct Point { x: int, y: int }\n\nfn test() -> Result<Point, string> {\n  Ok(Point { x: 10, y: 20 })\n}\n"
---
package main

import (
	"fmt"
	lisette "github.com/ivov/lisette/prelude"
)

type Point struct {
	x int
	y int
}

func (p Point) String() string {
	return fmt.Sprintf("Point { x: %v, y: %v }", p.x, p.y)
}

func test() lisette.Result[Point, string] {
	return lisette.MakeResultOk[Point, string](Point{
		x: 10,
		y: 20,
	})
}
