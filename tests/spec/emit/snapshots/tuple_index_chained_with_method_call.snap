---
package main

import lisette "github.com/ivov/lisette/prelude"

func test() lisette.Option[int] {
	items := lisette.MakeTuple2([]int{1, 2, 3}, []int{4, 5, 6})
	return lisette.SliceGet(items.First, 0)
}
