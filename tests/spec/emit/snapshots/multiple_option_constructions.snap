---
source: tests/spec/emit/result_option_patterns.rs
description: "input: \nfn test(flag: bool) -> Option<int> {\n  if flag {\n    Some(42)\n  } else {\n    None\n  }\n}\n"
---
package main

import lisette "github.com/ivov/lisette/prelude"

func test(flag bool) lisette.Option[int] {
	if flag {
		return lisette.MakeOptionSome[int](42)
	}
	return lisette.MakeOptionNone[int]()
}
