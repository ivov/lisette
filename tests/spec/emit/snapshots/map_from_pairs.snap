package main

import lisette "github.com/ivov/lisette/prelude"

func test() map[string]int {
	return lisette.MapFrom([]lisette.Tuple2[string, int]{
		lisette.MakeTuple2("alice", 95),
		lisette.MakeTuple2("bob", 82),
	})
}
